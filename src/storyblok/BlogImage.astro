---
import Image from "../components/Image.astro";

interface Props {
  src: string;
  alt: string;
  title: string;
  attribution?: string;
  source?: string;
  annotations?: {
    x: number;
    y: number;
    label: string;
    anchor: string;
  }[];
}
---

<Image
  src={Astro.props.src}
  alt={Astro.props.alt}
  title={Astro.props.title}
  attribution={Astro.props.attribution}
  source={Astro.props.source}
  annotations={Astro.props.annotations}
/>
